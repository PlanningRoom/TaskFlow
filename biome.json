{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "extends": ["./packages/config/biome.base.json"],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/build",
      "!**/coverage",
      "!**/node_modules",
      "!**/.turbo",
      "!**/generated",
      "!**/packages/api-types/openapi.json",
      "!**/apps/api",
      "!**/infra",
      "!**/docs",
      "!**/episodes"
    ]
  },
  "overrides": [
    {
      "includes": ["**/*.css"],
      "linter": {
        "rules": {
          "suspicious": {
            "noUnknownAtRules": "off"
          },
          "complexity": {
            "noImportantStyles": "off"
          }
        }
      }
    }
  ]
}
