# TaskFlow runtime configuration
# Copy to `.env.local` for local development. Never commit `.env.local`.
# In production, values are hydrated from AWS SSM Parameter Store at boot (ADR 073).

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info
APP_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:5173

# ── Backend (apps/api) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://taskflow:taskflow@db:5432/taskflow

# Sessions / CSRF (ADR 047, 051; TDD §11)
SESSION_COOKIE_NAME=taskflow_session
CSRF_COOKIE_NAME=taskflow_csrf
SESSION_SECRET=change-me-in-production-min-32-chars
SESSION_IDLE_TTL_DAYS=7
SESSION_ABSOLUTE_TTL_DAYS=30

# Real-time fan-out (ADR 044, 045; TDD §10). Set false to disable WS pub/sub.
REALTIME_ENABLED=true

# CORS (ADR 083) — comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate limiting (ADR 052) — overrides only; defaults baked into code
RATE_LIMIT_LOGIN_PER_IP=5/minute
RATE_LIMIT_LOGIN_PER_EMAIL=10/minute
RATE_LIMIT_SIGNUP_PER_IP=3/hour
RATE_LIMIT_PASSWORD_RESET_PER_IP=3/hour
RATE_LIMIT_PASSWORD_RESET_PER_EMAIL=3/hour
RATE_LIMIT_INVITES_PER_WORKSPACE=20/hour
RATE_LIMIT_AUTHENTICATED_DEFAULT=120/minute

# ── Email (ADR 067) ──────────────────────────────────────────────────────────
# dev: smtp → MailHog;  prod: resend → Resend HTTP API (swapped from SES in I2)
EMAIL_BACKEND=smtp
EMAIL_FROM=no-reply@taskflow.local
EMAIL_FROM_NAME=TaskFlow
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
# prod only — Resend API key, hydrated from SSM /taskflow/prod/resend_api_key
RESEND_API_KEY=

# Background jobs (ADR 069). Set false to skip APScheduler in tests / one-off scripts.
SCHEDULER_ENABLED=true
# When unset the pg_dump job logs `backup.skipped` and no-ops (ADR 074 dev posture).
S3_BACKUPS_BUCKET=

# ── Frontend (apps/web) ──────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/ws

# ── Production-only (hydrated from SSM; ADR 073) ─────────────────────────────
# TLS is Cloudflare edge + a Cloudflare Origin CA cert on the host (ADR 085) —
# no certbot. DNS + email auth (SPF/DKIM/DMARC) live in Cloudflare/Resend.
AWS_REGION=us-east-1
S3_BACKUPS_BUCKET=taskflow-backups-000000000000-us-east-1
S3_SOURCE_MAPS_BUCKET=taskflow-source-maps-000000000000-us-east-1
PUBLIC_HOSTNAME=taskflow.example.com
EMAIL_FROM_ADDRESS=no-reply@taskflow.example.com
