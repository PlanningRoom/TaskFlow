{
  "name": "taskflow",
  "version": "0.0.0",
  "private": true,
  "description": "TaskFlow — workspace task management",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.17.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "gen:api": "turbo run gen:api",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "turbo": "2.9.14",
    "typescript": "5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc}": ["biome check --write --no-errors-on-unmatched"]
  }
}
